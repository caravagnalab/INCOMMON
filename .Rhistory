toplot = lapply(1:nrow(x$input), function(i){
dplyr::tibble(
n_rep = n_rep[,i],
gene = x$input[i,]$gene,
id = paste0(x$input[i,]$gene, ' (', x$input[i,]$ref, '-', x$input[i,]$alt, ')'),
NV =  x$input[i,]$NV,
DP =  x$input[i,]$DP,
k = km_rep[[i]]$k,
m = km_rep[[i]]$m,
test = ifelse(x$input[i,]$post_pred_p.value_NV >= .15 & x$input[i,]$post_pred_p.value_NV <= .85, 'PPC PASS', 'PPC FAIL')
)}) %>% do.call(rbind, .)
plot_binom = ggplot2::ggplot(toplot)+
ggplot2::geom_histogram(
ggplot2::aes(
x = n_rep,
fill = factor(m)
),
alpha = 0.8,
binwidth = 1
) +
ggplot2::geom_vline(
ggplot2::aes(xintercept = NV, group = id, color = test), linetype = 'longdash')+
ggplot2::scale_color_manual(values = c('PPC PASS' = 'forestgreen', 'PPC FAIL' = 'firebrick'), name = '')+
scale_fill_viridis_d(option = 'C',direction = 1)+
# scale_color_gradientn(colours = c('indianred','firebrick'))+
# scale_fill_viridis_d(option = 'F')+
my_ggplot_theme()+
ggplot2::theme(
axis.text.y = ggplot2::element_blank(),
axis.text.y.right= ggplot2::element_text(),
axis.ticks.y.left = ggplot2::element_blank(),
strip.text.y.left = ggplot2::element_text(angle = 0, colour = 'black'),
strip.background = element_rect(fill = 'white', colour = 'black'),
)+
ggplot2::labs(
y = '',
x = 'Reads with the variant',
fill = 'Multiplicity (m)',
color = ''
)+
ggplot2::facet_wrap(~id, ncol = 1, strip.position = 'left')
toplot = x$input %>%
mutate(id = paste0(gene, ' (', ref, '-', alt, ')')) %>%
select(gene, id, map_k, map_m, z_km) %>% unnest(z_km)
pg = toplot %>%
complete(
k = 1:8,
m = 1:8,
gene,
map_k,
map_m,
z_km = 1e-40) %>%
mutate(z_km = ifelse(z_km <= 1e-40, 1e-40, z_km)) %>%
ggplot(aes(x=k,y=m))+
geom_tile(aes(fill = log10(z_km)))+
scale_fill_viridis_c(labels = scales::label_math(10^.x))+
guides(fill = guide_colorbar(title = 'P(k,m)', position = 'right'))+
my_ggplot_theme()
leg = ggpubr::get_legend(pg)
leg = ggpubr::as_ggplot(leg)
p_density = toplot %>%
complete(
k = 1:8,
m = 1:8,
gene,
id,
map_k,
map_m,
z_km = 1e-40) %>%
mutate(
z_km = ifelse(z_km <= 1e-40, 1e-40, z_km)) %>%
ggplot(aes(x=k,y=m))+
geom_contour_filled(aes(z = log10(z_km)), bins = 50, alpha = 0.85)+
guides(fill = 'none')+
coord_cartesian(expand = FALSE, clip = 'off')+
geom_point(data = toplot %>% group_by(id) %>%  arrange(desc(z_km), .by_group = T) %>% slice_head(n=1) %>%
mutate(what = 'MAP estimate'),
aes(color = what, shape = what))+
scale_color_manual(values = 'firebrick')+
scale_shape_manual(values = 8)+
scale_y_continuous(position = 'right') +
facet_wrap(~gene, ncol = 1, strip.position = 'left')+
my_ggplot_theme()+
theme(
strip.text.y.left = element_text(angle = 0),
strip.background = element_blank(),panel.grid = element_line(colour = 'black'),
legend.position = 'bottom',
axis.text = element_text(),
axis.title = element_text()
)+
labs(x = 'Total CN (k)', y = 'Multiplicity (m)', color = '', shape = '')
# p_density = p_density/leg+plot_layout(heights = c(10,1))
