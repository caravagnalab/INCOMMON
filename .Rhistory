library(tidyverse)
x = readRDS('./data/comp_data_066_07022025.RDS') %>% as.tibble()
y = readRDS('./results/msk_met_classified_expectation.rds') %>% filter(wk <= 8)
x = x %>%
as.tibble() %>%
select(sample, Purity, Class, CCF_hi, Subclonal, gene, tumor_type, NV, DP, LCN, MCN, TCN) %>%
left_join(
y %>% select(sample, purity, purity_map, gene, gene_role, tumor_type, NV, DP, wm, wk, starts_with('post_'), starts_with('bayes'))
) %>%
filter(!is.na(wk))
x = x %>%
mutate(
good_DP = post_pred_p.value_DP >= .05 & post_pred_p.value_DP <= .95,
good_NV = post_pred_p.value_NV >= .05 & post_pred_p.value_NV <= .95,
good_purity = bayes_p_purity >= .05 & bayes_p_purity <= .95,
good_rate = bayes_p_x >= .05 & bayes_p_x <= .95
) %>%
mutate(FACETS_FMA = MCN/TCN) %>%
mutate(good_fit = (good_DP & good_NV & good_purity & good_rate))
x = x %>%
mutate(
FAM = wm/wk) %>%
filter(!is.na(gene_role)) %>%
mutate(class = case_when(
gene_role == 'oncogene' & FAM <= .33 ~ 'PWK',
gene_role == 'TSG' & FAM <= .25 ~ 'PWK',
gene_role == 'oncogene' & FAM > .33 & FAM < .66 ~ 'BK',
gene_role == 'TSG' & FAM > .25 & FAM < .75 ~ 'BK',
gene_role == 'TSG' & FAM >= .75 ~ 'PMK',
gene_role == 'oncogene' & FAM >= .66 ~ 'PMK'
))
x = x %>% filter(TCN<=8)
x = x %>% mutate(id = paste(sample, gene, NV, DP, sep = ":"))
xx = x %>%
as_tibble() %>%
filter(TCN <= 8) %>%
rowwise() %>%
mutate(LCN_i = min(wm, wk-wm), MCN_i = max(wm, wk-wm), TCN_i = wk) %>%
select(id, gene_role, CCF_hi, wm, wk, LCN_i, MCN_i, TCN_i, LCN, MCN, TCN) %>%
ungroup()
xx %>%
mutate(dk = abs(TCN_i-TCN), dm = abs(MCN_i-MCN), dfam = abs((MCN_i/TCN_i)-(MCN/TCN))) %>%
select(id, dk, dm, dfam) %>%
summarise(sk = sd(dk), sm = sd(dm), sd_fam = sd(dfam), dm = median(dm), dk = median(dk), dfam = median(dfam))
plot_inc_vs_facets = xx %>%
filter(TCN<=8) %>%
pivot_longer(cols = c(LCN_i, LCN, MCN, MCN_i, TCN, TCN_i)) %>%
mutate(
var = case_when(
grepl('LCN', name) ~ 'LCN',
grepl('MCN', name) ~ 'MCN',
grepl('TCN', name) ~ 'TCN'
),
name = ifelse(grepl('_i', name), 'INCOMMON', 'FACETS')
) %>%
mutate(subclonal = (CCF_hi < .9)) %>%
select(-c(gene_role, wm, wk)) %>%
pivot_wider(names_from = name, values_from = value) %>%
unnest(cols = c(INCOMMON, FACETS)) %>%
ggplot(aes(x = var, y = abs(INCOMMON-FACETS)))+
geom_violin(scale = 'width', draw_quantiles = seq(0,1,.25), fill = 'deepskyblue')+
my_ggplot_theme()+
labs(y = 'Absolute Deviation (INCOMMON vs FACETS)', x = 'Copy Number Value',
title = 'MSK-IMPACT (Bielski et al., 2018)',
subtitle = paste0('N = ',length(unique(x$sample)), ' samples; ', 'M = ',nrow(x), ' mutations\n', 'Median depth = ', median(x$DP), '; Median purity = ', median(x$Purity) %>% round(2)))
plot_inc_vs_facets
