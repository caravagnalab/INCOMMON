pivot_wider(names_from = name, values_from = value) %>%
unnest(cols = c(INCOMMON, FACETS)) %>%
ggplot(aes(x = INCOMMON, y = FACETS))+
geom_point(position = position_jitter(height = 0.2), size = .5)+
facet_wrap(~var)+
INCOMMON:::my_ggplot_theme()
ggsave(plot = plot, filename = './figures/Panels/ccf_facets_scatter.pdf', height = 7, width = 4)
ggsave(plot = plot, filename = './figures/Panels/ccf_facets_scatter.png', height = 6, width = 4)
