pivot_longer(everything(),
names_to = c("column", "percentile"),
names_sep = "_") %>%
pivot_wider(names_from = percentile, values_from = value)) %>%
mutate(`Observed Value` = ifelse(post_pred_p.value_DP <= .85 & post_pred_p.value_DP >= .15, 'PPC PASS', 'PPC FAIL'))
ppois = ggplot2::ggplot(toplot, aes(x = map_k, y = DP))+
ggplot2::geom_point()+
ggplot2::geom_ribbon(ggplot2::aes(ymin = `5%`, ymax = `95%`), linetype=2, alpha=0.5, fill = 'darkgrey')+
ggplot2::geom_abline(
data = dplyr::tibble(value = c(purity_map), eta_fit = eta_map, purity = c('Input Purity', 'MAP Purity')),
linetype = 'longdash',
ggplot2::aes(
slope = value*eta_fit,
intercept = 2*(1-value)*eta_map), color = 'darkgrey')+
ggplot2::geom_point(ggplot2::aes(y = DP, fill = `Observed Value`), shape = 21, stroke = 0, size = 3)+
ggplot2::scale_fill_manual(
values = c('PPC PASS' = 'forestgreen', 'PPC FAIL' = 'firebrick'))+
ggrepel::geom_label_repel(ggplot2::aes(x = map_k, y = DP, label = paste0(gene, ' (',paste(ref, alt, sep = '-'), ')')),
force_pull =  -0.05)+
my_ggplot_theme()+
ggplot2::scale_x_continuous(expand = c(0.01,0.0))+
ggplot2::scale_y_continuous(expand = c(0.01,0.0))+
ggplot2::guides(size = ggplot2::guide_legend(title = 'Posterior Prob'))+
ggplot2::labs(
x = 'Total CN (k)',
y = 'Total reads',
fill = '',
colour = ''
)+
ggplot2::xlim(1,max(toplot$map_k))
toplot = rbind(
tibble(source = 'Prior Distribution', value = eta_prior_rep),
tibble(source = 'Posterior Distribution', value = eta_rep)
)
bayes_p_color = ifelse(bayes_p_eta >= .15 & bayes_p_eta <= .85, 'forestgreen', 'firebrick')
p_eta = toplot %>%
ggplot2::ggplot()+
ggplot2::geom_histogram(ggplot2::aes(x = value, alpha = source), bins = 100, fill = 'darkgrey', position = 'identity')+
ggplot2::scale_alpha_manual(values = c(0.9,0.35))+
ggplot2::geom_vline(ggplot2::aes(xintercept = median(eta_rep)), color = ggplot2::alpha('darkgrey', alpha = 0.9), linetype = 'longdash')+
ggplot2::geom_vline(ggplot2::aes(xintercept = median(eta_prior_rep)), color = ggplot2::alpha('darkgrey', alpha = 0.35), linetype = 'longdash')+
ggplot2::scale_x_continuous(breaks = scales::pretty_breaks(n=3))+
ggplot2::scale_y_continuous(breaks = scales::pretty_breaks(n=3))+
my_ggplot_theme()+
ggplot2::theme(
panel.border = ggplot2::element_rect(
color = bayes_p_color,
fill = NA,
linewidth = 2)
)+
ggplot2::labs(
alpha = '',
y = '',
x = bquote('Expected counts per allele'~eta)
)
toplot = rbind(
tibble(source = 'Prior Distribution', value = purity_prior_rep),
tibble(source = 'Posterior Distribution', value = purity_rep)
)
bayes_p_color = ifelse(bayes_p_purity >= .15 & bayes_p_purity <= .85, 'forestgreen', 'firebrick')
p_purity = toplot %>%
